# U-Cloud Credentials
U_USERNAME="你的U校园账号"
U_PASSWORD="你的U校园密码"

DEEPSEEK_API_KEY="你的DeepSeek API Key"
# 以上内容必填

# 运行配置 (可选)

# true 表示只完成“未完成”项目
# false 表示完成所有“必修项目”, 无论是否完成
# 默认为 true
PROCESS_ONLY_INCOMPLETE_TASKS="True"

# true 表示发送 prompt 前和最终提交答案前不需要手动同意
# false 表示均需手动同意。
# 默认为 true
AUTO_MODE_NO_CONFIRM="True"

# true 表示不调用已存储的正确答案, 所有答案从ai获取
# false 表示会调用存储的答案值, 无有效答案时调用 ai
# 默认为false
FORCE_AI="False"

# 浏览器通道：默认使用系统 Microsoft Edge，减少 Playwright Chromium 下载体积
# 可选值：msedge / chrome / chromium
BROWSER_CHANNEL="msedge"

# 主浏览器不可用时的回退通道，多个值用英文逗号分隔
# chromium 表示 Playwright 自带 Chromium，会在需要时按需下载/修复
BROWSER_FALLBACK_CHANNELS="chromium"

# true 表示启动 Chromium 时启用假麦克风设备，适合无实体麦克风/WSL/远程桌面环境
# 默认为 true
USE_FAKE_MICROPHONE="True"

# true 表示当页面仍然拿不到麦克风时，自动注入页面级虚拟音频流兜底
# 默认为 true
MOCK_MICROPHONE_WHEN_MISSING="True"
